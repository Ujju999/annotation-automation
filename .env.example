# YOLO weights for your trained classes. LEAVE EMPTY to run SAM3-only:
# with no model, every label routes to SAM3's open-vocab text prompts, so you can
# annotate (e.g. "drone") without training anything. Set a path once you have weights.
YOLO_MODEL_PATH=

# YOLO task: "detect" (boxes — MVP) or "segment" (masks → polygons — later)
YOLO_TASK=detect

# Open-vocab engine for labels the YOLO model doesn't know (text-prompted).
#   gdino         = Grounding DINO (default; GPU, boxes, fast)
#   yolo_world    = YOLO-World via ultralytics (GPU, boxes, fastest; no new deps)
#   grounded_sam2 = Grounding DINO + SAM 2 (GPU, boxes + masks)
#   florence2     = Florence-2 (GPU, boxes + masks)
#   sam3          = legacy osam/SAM3 (CPU-only; needs: pip install ".[osam]")
OPEN_VOCAB_BACKEND=gdino

# Grounding DINO model id (gdino backend). "-tiny" is smaller/faster, "-base" more accurate.
GDINO_MODEL_ID=IDEA-Research/grounding-dino-base

# YOLO-World weights (yolo_world backend). "x" = most accurate, "s"/"m" = smaller/faster.
# YOLO_WORLD_MODEL=yolov8x-worldv2.pt

# SAM 2 checkpoint (grounded_sam2 backend). "-large" = best masks, "-tiny" = fastest.
# SAM2_MODEL_ID=facebook/sam2-hiera-large

# osam model id, used ONLY when OPEN_VOCAB_BACKEND=sam3 (bare name; osam appends :latest).
OSAM_MODEL=sam3

# Separate score thresholds (SAM3 wants lower than YOLO)
YOLO_SCORE_THRESHOLD=0.3
SAM3_SCORE_THRESHOLD=0.1
IOU_THRESHOLD=0.5
MAX_DETECTIONS=100

# SAM3 image-embedding cache depth
EMBEDDING_CACHE_SIZE=10

# Prediction model_version label shown in Label Studio
MODEL_VERSION=yolo+sam3-v1

# Server port
PORT=9090

# --- Connect to Label Studio -------------------------------------------------
# REQUIRED when your annotators UPLOAD images into Label Studio (so this backend can
# fetch them back to run the model). NOT needed if you import images by URL.
# Get the token in Label Studio: bottom-left avatar → Account & Settings → Access Token
# (use the "Legacy Token" if both Personal and Legacy are offered).
LABEL_STUDIO_URL=http://localhost:8080
LABEL_STUDIO_EMAIL=admin@example.com
LABEL_STUDIO_PASSWORD=yourpassword

# Apple Silicon: let unsupported MPS ops fall back to CPU (YOLO segment, later)
PYTORCH_ENABLE_MPS_FALLBACK=1

# NOTE: SAM3 runs on CPU via onnxruntime in osam 0.4.0 — no device override exists.
